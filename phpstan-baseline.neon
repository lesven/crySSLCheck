parameters:
	ignoreErrors:
		-
			message: '#^Using nullsafe method call on non\-nullable type DateTimeImmutable\. Use \-\> instead\.$#'
			identifier: nullsafe.neverNull
			count: 1
			path: src/Command/ScanCommand.php

		-
			message: '#^Call to an undefined method Symfony\\Component\\Security\\Core\\User\\UserInterface\:\:setPassword\(\)\.$#'
			identifier: method.notFound
			count: 1
			path: src/Controller/SecurityController.php

		-
			message: '#^Parameter \#1 \$user of method Symfony\\Component\\PasswordHasher\\Hasher\\UserPasswordHasherInterface\:\:hashPassword\(\) expects Symfony\\Component\\Security\\Core\\User\\PasswordAuthenticatedUserInterface, Symfony\\Component\\Security\\Core\\User\\UserInterface\|null given\.$#'
			identifier: argument.type
			count: 1
			path: src/Controller/SecurityController.php

		-
			message: '#^Parameter \#1 \$user of method Symfony\\Component\\PasswordHasher\\Hasher\\UserPasswordHasherInterface\:\:isPasswordValid\(\) expects Symfony\\Component\\Security\\Core\\User\\PasswordAuthenticatedUserInterface, Symfony\\Component\\Security\\Core\\User\\UserInterface\|null given\.$#'
			identifier: argument.type
			count: 1
			path: src/Controller/SecurityController.php

		-
			message: '#^If condition is always true\.$#'
			identifier: if.alwaysTrue
			count: 1
			path: src/DataCollector/MailDataCollector.php

		-
			message: '#^Method App\\DataCollector\\MailDataCollector\:\:getAttempts\(\) return type has no value type specified in iterable type array\.$#'
			identifier: missingType.iterableValue
			count: 1
			path: src/DataCollector/MailDataCollector.php

		-
			message: '#^Ternary operator condition is always true\.$#'
			identifier: ternary.alwaysTrue
			count: 1
			path: src/DataCollector/MailDataCollector.php

		-
			message: '#^Property App\\Entity\\Domain\:\:\$findings with generic interface Doctrine\\Common\\Collections\\Collection does not specify its types\: TKey, T$#'
			identifier: missingType.generics
			count: 1
			path: src/Entity/Domain.php

		-
			message: '#^Property App\\Entity\\Domain\:\:\$id \(int\|null\) is never assigned int so it can be removed from the property type\.$#'
			identifier: property.unusedType
			count: 1
			path: src/Entity/Domain.php

		-
			message: '#^Method App\\Entity\\Finding\:\:getDetails\(\) return type has no value type specified in iterable type array\.$#'
			identifier: missingType.iterableValue
			count: 1
			path: src/Entity/Finding.php

		-
			message: '#^Method App\\Entity\\Finding\:\:setDetails\(\) has parameter \$details with no value type specified in iterable type array\.$#'
			identifier: missingType.iterableValue
			count: 1
			path: src/Entity/Finding.php

		-
			message: '#^Property App\\Entity\\Finding\:\:\$details type has no value type specified in iterable type array\.$#'
			identifier: missingType.iterableValue
			count: 1
			path: src/Entity/Finding.php

		-
			message: '#^Property App\\Entity\\Finding\:\:\$id \(int\|null\) is never assigned int so it can be removed from the property type\.$#'
			identifier: property.unusedType
			count: 1
			path: src/Entity/Finding.php

		-
			message: '#^Property App\\Entity\\ScanRun\:\:\$findings with generic interface Doctrine\\Common\\Collections\\Collection does not specify its types\: TKey, T$#'
			identifier: missingType.generics
			count: 1
			path: src/Entity/ScanRun.php

		-
			message: '#^Property App\\Entity\\ScanRun\:\:\$id \(int\|null\) is never assigned int so it can be removed from the property type\.$#'
			identifier: property.unusedType
			count: 1
			path: src/Entity/ScanRun.php

		-
			message: '#^Property App\\Entity\\User\:\:\$id \(int\|null\) is never assigned int so it can be removed from the property type\.$#'
			identifier: property.unusedType
			count: 1
			path: src/Entity/User.php

		-
			message: '#^Class App\\Security\\UserProvider implements generic interface Symfony\\Component\\Security\\Core\\User\\UserProviderInterface but does not specify its types\: TUser$#'
			identifier: missingType.generics
			count: 1
			path: src/Security/UserProvider.php

		-
			message: '#^Method App\\Service\\CertificateAnalyzer\:\:analyze\(\) has parameter \$result with no value type specified in iterable type array\.$#'
			identifier: missingType.iterableValue
			count: 1
			path: src/Service/CertificateAnalyzer.php

		-
			message: '#^Method App\\Service\\CertificateAnalyzer\:\:analyze\(\) return type has no value type specified in iterable type array\.$#'
			identifier: missingType.iterableValue
			count: 1
			path: src/Service/CertificateAnalyzer.php

		-
			message: '#^Method App\\Service\\CertificateAnalyzer\:\:buildOkFinding\(\) has parameter \$result with no value type specified in iterable type array\.$#'
			identifier: missingType.iterableValue
			count: 1
			path: src/Service/CertificateAnalyzer.php

		-
			message: '#^Method App\\Service\\CertificateAnalyzer\:\:buildOkFinding\(\) return type has no value type specified in iterable type array\.$#'
			identifier: missingType.iterableValue
			count: 1
			path: src/Service/CertificateAnalyzer.php

		-
			message: '#^Method App\\Service\\CertificateAnalyzer\:\:checkCertExpiry\(\) has parameter \$result with no value type specified in iterable type array\.$#'
			identifier: missingType.iterableValue
			count: 1
			path: src/Service/CertificateAnalyzer.php

		-
			message: '#^Method App\\Service\\CertificateAnalyzer\:\:checkCertExpiry\(\) return type has no value type specified in iterable type array\.$#'
			identifier: missingType.iterableValue
			count: 1
			path: src/Service/CertificateAnalyzer.php

		-
			message: '#^Method App\\Service\\CertificateAnalyzer\:\:checkChainError\(\) has parameter \$result with no value type specified in iterable type array\.$#'
			identifier: missingType.iterableValue
			count: 1
			path: src/Service/CertificateAnalyzer.php

		-
			message: '#^Method App\\Service\\CertificateAnalyzer\:\:checkChainError\(\) return type has no value type specified in iterable type array\.$#'
			identifier: missingType.iterableValue
			count: 1
			path: src/Service/CertificateAnalyzer.php

		-
			message: '#^Method App\\Service\\CertificateAnalyzer\:\:checkRsaKeyLength\(\) has parameter \$result with no value type specified in iterable type array\.$#'
			identifier: missingType.iterableValue
			count: 1
			path: src/Service/CertificateAnalyzer.php

		-
			message: '#^Method App\\Service\\CertificateAnalyzer\:\:checkRsaKeyLength\(\) return type has no value type specified in iterable type array\.$#'
			identifier: missingType.iterableValue
			count: 1
			path: src/Service/CertificateAnalyzer.php

		-
			message: '#^Method App\\Service\\CertificateAnalyzer\:\:checkTlsVersion\(\) has parameter \$result with no value type specified in iterable type array\.$#'
			identifier: missingType.iterableValue
			count: 1
			path: src/Service/CertificateAnalyzer.php

		-
			message: '#^Method App\\Service\\CertificateAnalyzer\:\:checkTlsVersion\(\) return type has no value type specified in iterable type array\.$#'
			identifier: missingType.iterableValue
			count: 1
			path: src/Service/CertificateAnalyzer.php

		-
			message: '#^Method App\\Service\\CertificateAnalyzer\:\:computeDaysRemaining\(\) has parameter \$result with no value type specified in iterable type array\.$#'
			identifier: missingType.iterableValue
			count: 1
			path: src/Service/CertificateAnalyzer.php

		-
			message: '#^Method App\\Service\\FindingPersister\:\:persistFindings\(\) has parameter \$scanFindings with no value type specified in iterable type array\.$#'
			identifier: missingType.iterableValue
			count: 1
			path: src/Service/FindingPersister.php

		-
			message: '#^Method App\\Service\\FindingPersister\:\:persistFindings\(\) return type has no value type specified in iterable type array\.$#'
			identifier: missingType.iterableValue
			count: 1
			path: src/Service/FindingPersister.php

		-
			message: '#^Method App\\Service\\FindingPersister\:\:persistFindings\(\) should return array\<array\{finding_type\: string, severity\: string, details\: array, id\: int, status\: string\}\> but returns list\<array\{finding_type\: string, severity\: string, details\: array, status\: ''known''\|''new''\}\>\.$#'
			identifier: return.type
			count: 1
			path: src/Service/FindingPersister.php


		-
			message: '#^Method App\\Service\\ScanService\:\:runSingleScan\(\) return type has no value type specified in iterable type array\.$#'
			identifier: missingType.iterableValue
			count: 1
			path: src/Service/ScanService.php

		-
			message: '#^Method App\\Service\\ScanService\:\:scanDomain\(\) return type has no value type specified in iterable type array\.$#'
			identifier: missingType.iterableValue
			count: 1
			path: src/Service/ScanService.php

		-
			message: '#^Property App\\Service\\ScanService\:\:\$scanRunRepository is never read, only written\.$#'
			identifier: property.onlyWritten
			count: 1
			path: src/Service/ScanService.php

		-
			message: '#^Method App\\Service\\TlsConnector\:\:extractCertificateInfo\(\) return type has no value type specified in iterable type array\.$#'
			identifier: missingType.iterableValue
			count: 1
			path: src/Service/TlsConnector.php

		-
			message: '#^Method App\\Service\\TlsConnector\:\:extractPublicKeyInfo\(\) return type has no value type specified in iterable type array\.$#'
			identifier: missingType.iterableValue
			count: 1
			path: src/Service/TlsConnector.php

		-
			message: '#^Method App\\Service\\TlsConnector\:\:extractStreamMetadata\(\) return type has no value type specified in iterable type array\.$#'
			identifier: missingType.iterableValue
			count: 1
			path: src/Service/TlsConnector.php
